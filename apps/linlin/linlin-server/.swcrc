{
    "$schema": "https://json.schemastore.org/swcrc",
    "sourceMaps": true,
    "jsc": {
        "parser": {
            "syntax": "typescript",
            "decorators": true,
            "dynamicImport": true
        },
        "transform": {
            "legacyDecorator": true,
            "decoratorMetadata": true
        },
        "baseUrl": ".",
        "paths": {
            "@/*": ["./src/*"],
            "@/interfaces/*": ["../interfaces/*"]
        },
        "target": "es2022",
        "keepClassNames": true
    },
    "minify": false,
    "module": {
        "type": "commonjs"
    }
}
