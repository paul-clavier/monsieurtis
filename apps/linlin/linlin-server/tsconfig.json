{
    "extends": "@monsieurtis/tsconfig/server.json",
    "compilerOptions": {
        "noEmit": true,
        "noImplicitAny": false,
        "strictBindCallApply": false,
        "noFallthroughCasesInSwitch": false,
        "noUncheckedIndexedAccess": false,
        "baseUrl": ".",
        "paths": {
            "@/*": ["./src/*"],
            "@/interfaces/*": ["../interfaces/*"],
            "@monsieurtis/core": ["../../../lib/core/src/index.ts"],
            "@monsieurtis/prisma": ["../../../lib/packages/prisma/src/index.ts"]
        }
    },
    "include": ["src", "../interfaces"]
}
