{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "lib": ["ES2022", "DOM", "DOM.Iterable"],
        "jsx": "react-jsx",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "isolatedModules": true,
        "resolveJsonModule": true,
        "verbatimModuleSyntax": true,
        "noEmit": true,
        "paths": {
            "@monsieurtis/ui/*": ["./*"]
        }
    },
    "include": ["components", "hooks", "lib"]
}
